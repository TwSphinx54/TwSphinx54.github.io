---
import { Icon } from "astro-icon/components";
---

<!-- Abstract / Image Modal Common Elements and Scripts -->
<div
	id="img-modal"
	class="pointer-events-none fixed inset-0 z-[110] flex hidden items-center justify-center bg-black/40 p-4 opacity-0 shadow-2xl backdrop-blur-sm transition-all duration-300"
>
	<div
		class="pointer-events-auto relative mt-16 flex max-h-[90vh] max-w-[90vw] scale-95 items-center justify-center transition-transform duration-300"
		id="img-modal-content"
	>
		<button
			id="img-modal-close"
			class="ui-press absolute right-3 top-3 z-20 inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border border-zinc-200/70 bg-white/90 text-accent shadow-md hover:bg-accent/10 dark:border-zinc-700/70 dark:bg-zinc-900/90 dark:hover:bg-accent/20"
			aria-label="Close image modal"
		>
			<Icon name="lucide:x" class="func-icon" width="16" height="16" aria-hidden="true" />
		</button>
		<img
			id="img-modal-img"
			src=""
			alt="Large image"
			class="max-h-[90vh] max-w-full rounded-2xl object-contain shadow-2xl ring-1 ring-white/20"
		/>
	</div>
</div>

<script>
	function initAbstractToggles() {
		const buttons = document.querySelectorAll(".abstract-btn");
		buttons.forEach((btn) => {
			btn.addEventListener("click", (e) => {
				e.preventDefault();
				const id = btn.getAttribute("data-abstract-id");
				if (!id) return;

				const contentId = id.replace("abstract-", "abstract-content-");
				const content = document.getElementById(contentId);
				const chev = btn.querySelector(".chev");
				if (!content) return;

				const isCollapsed = content.getAttribute("data-collapsed") === "true";

				if (isCollapsed) {
					content.style.maxHeight = content.scrollHeight + "px";
					content.style.opacity = "1";
					content.setAttribute("data-collapsed", "false");
					btn.setAttribute("aria-expanded", "true");
					chev?.classList.add("rotate-180");

					// Allow auto height after transition
					setTimeout(() => {
						if (content.getAttribute("data-collapsed") === "false") {
							content.style.maxHeight = "none";
						}
					}, 310);
				} else {
					// Set height back to scrollHeight for transition to 0
					content.style.maxHeight = content.scrollHeight + "px";
					content.offsetHeight; // force reflow
					content.style.maxHeight = "0";
					content.style.opacity = "0";
					content.setAttribute("data-collapsed", "true");
					btn.setAttribute("aria-expanded", "false");
					chev?.classList.remove("rotate-180");
				}
			});
		});
	}

	function initImageModal() {
		const modal = document.getElementById("img-modal");
		const modalContent = document.getElementById("img-modal-content");
		const modalImg = document.getElementById("img-modal-img") as HTMLImageElement;
		const modalClose = document.getElementById("img-modal-close");

		if (!modal || !modalImg) return;

		function open(src: string) {
			modalImg.src = src;
			modal?.classList.remove("hidden", "pointer-events-none", "opacity-0");
			modal?.classList.add("opacity-100");
			modalContent?.classList.remove("scale-95");
			modalContent?.classList.add("scale-100");
			document.body.style.overflow = "hidden";
			(modalClose as HTMLElement)?.focus?.();
		}

		function close() {
			modal?.classList.add("pointer-events-none", "opacity-0");
			modal?.classList.remove("opacity-100");
			modalContent?.classList.remove("scale-100");
			modalContent?.classList.add("scale-95");
			document.body.style.overflow = "";
			setTimeout(() => {
				if (modal?.classList.contains("opacity-0")) {
					modal?.classList.add("hidden");
					modalImg.src = "";
				}
			}, 310);
		}

		modalClose?.addEventListener("click", close);
		modal.addEventListener("click", (e) => {
			if (e.target === modal) close();
		});
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape") close();
		});

		document.addEventListener("click", (e) => {
			const t = e.target;
			if (!(t instanceof HTMLImageElement)) return;
			if (!t.classList.contains("pub-thumb-img")) return;
			const src = t.dataset.fullsrc || t.currentSrc || t.src;
			if (src) open(src);
		});
	}

	function setup() {
		initAbstractToggles();
		initImageModal();
	}

	setup();
	document.addEventListener("astro:after-swap", setup);
</script>
