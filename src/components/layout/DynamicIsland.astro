---
import { menuLinks } from "@/site-config";
import { Icon } from "astro-icon/components";

const url = new URL(Astro.request.url);
const currentLink = menuLinks.find(
	(link) => url.pathname === link.path || (link.path !== "/" && url.pathname.startsWith(link.path)),
) ?? menuLinks[0];
---

<div
	id="island-wrapper"
	class="pointer-events-none fixed inset-x-3 top-3 z-[100] flex justify-center sm:top-4"
>
	<div
		id="dynamic-island"
		class="desktop-island cubic-bezier-apple pointer-events-auto hidden items-center gap-x-2 rounded-full border border-white/20 bg-white/30 p-1.5 opacity-0 shadow-[0_12px_44px_-10px_rgba(0,0,0,0.15)] ring-1 ring-white/10 backdrop-blur-3xl transition-all duration-500 will-change-transform hover:scale-[1.02] hover:bg-white/45 hover:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.25)] dark:border-white/5 dark:bg-black/35 dark:shadow-[0_20px_80px_rgba(0,0,0,0.5)] dark:ring-white/5 dark:hover:bg-black/45 sm:gap-x-4 sm:p-2 md:flex"
		style="transform: scaleY(0.86) translateY(-28px);"
	>
		<a
			href="/"
			class="group flex items-center gap-x-2 rounded-full px-2.5 py-1 transition-all duration-300 hover:bg-zinc-800/5 dark:hover:bg-white/10 sm:px-3.5"
		>
			<span
				class="whitespace-nowrap text-sm font-bold tracking-tight text-textColor transition-transform group-active:scale-95 sm:text-base"
			>
				PAN&nbsp;&nbsp;Xu
			</span>
		</a>

		<nav class="flex items-center gap-x-0.5 sm:gap-x-1">
			{
				menuLinks.map((link) => {
					const isActive =
						url.pathname === link.path || (link.path !== "/" && url.pathname.startsWith(link.path));
					return (
						<a
							href={link.path}
							class={`relative rounded-full px-2.5 py-1 text-[11px] font-bold tracking-wider transition-all duration-300 sm:px-3 sm:text-xs ${
								isActive
									? "text-accent"
									: "text-zinc-500 hover:bg-zinc-800/5 hover:text-textColor dark:text-zinc-400 dark:hover:bg-white/10 dark:hover:text-white"
							} active:scale-95`}
						>
							{isActive && (
								<div
									class="absolute inset-0 z-[-1] rounded-full border border-accent/20 bg-accent/15 dark:bg-accent/20"
									aria-hidden="true"
								/>
							)}
							{link.title.toUpperCase()}
						</a>
					);
				})
			}
		</nav>
	</div>

	<div
		id="dynamic-island-tools"
		class="desktop-island cubic-bezier-apple pointer-events-auto hidden absolute left-1/2 top-0 items-center gap-x-1 rounded-full border border-white/20 bg-white/30 p-1 opacity-0 shadow-[0_12px_44px_-10px_rgba(0,0,0,0.15)] ring-1 ring-white/10 backdrop-blur-3xl transition-all duration-500 will-change-transform dark:border-white/5 dark:bg-black/35 dark:shadow-[0_20px_80px_rgba(0,0,0,0.5)] dark:ring-white/5 sm:p-1.5 md:flex"
		style="transform: translateX(-50%) scaleY(0.86) translateY(-28px);"
	>
		<button
			id="island-theme-toggle"
			class="group flex h-8 w-8 items-center justify-center rounded-full transition-all duration-300 hover:bg-zinc-800/5 dark:hover:bg-white/10 sm:h-9 sm:w-9"
			aria-label="Toggle theme"
		>
			<Icon name="lucide:sun" class="func-icon h-3.5 w-3.5 text-zinc-600 dark:hidden sm:h-4 sm:w-4" />
			<Icon name="lucide:moon" class="func-icon hidden h-3.5 w-3.5 text-zinc-400 dark:block sm:h-4 sm:w-4" />
		</button>

		<div class="h-4 w-[1px] bg-zinc-400/20 dark:bg-zinc-600/30 sm:h-5"></div>

		<button
			id="island-scroll-top"
			class="group flex h-8 w-8 items-center justify-center rounded-full transition-all duration-300 hover:bg-zinc-800/5 dark:hover:bg-white/10 sm:h-9 sm:w-9"
			aria-label="Scroll to top"
		>
			<Icon
				name="lucide:arrow-up"
				class="func-icon h-3.5 w-3.5 text-zinc-600 transition-transform group-hover:-translate-y-0.5 dark:text-zinc-400 sm:h-4 sm:w-4"
			/>
		</button>
	</div>

	<div class="mobile-island hidden pointer-events-auto">
		<button
			id="mobile-island-toggle"
			class="mobile-island-trigger"
			aria-expanded="false"
			aria-controls="mobile-island-menu"
			type="button"
		>
			<span id="mobile-island-label">{currentLink.title}</span>
			<Icon name="lucide:chevron-down" class="mobile-island-chevron func-icon h-4 w-4" />
		</button>
		<div class="mobile-island-actions">
			<button id="mobile-theme-toggle" class="mobile-island-action" type="button" aria-label="Toggle theme">
				<Icon name="lucide:sun" class="func-icon h-4 w-4 text-zinc-600 dark:hidden" />
				<Icon name="lucide:moon" class="func-icon hidden h-4 w-4 text-zinc-400 dark:block" />
			</button>
			<button id="mobile-scroll-top" class="mobile-island-action" type="button" aria-label="Scroll to top">
				<Icon name="lucide:arrow-up" class="func-icon h-4 w-4 text-zinc-600 dark:text-zinc-400" />
			</button>
		</div>
		<div id="mobile-island-menu" class="mobile-island-menu" aria-hidden="true">
			{menuLinks.map((link) => {
				const isActive =
					url.pathname === link.path || (link.path !== "/" && url.pathname.startsWith(link.path));
				return (
					<a href={link.path} class={`mobile-island-link ${isActive ? "is-active" : ""}`}>
						{link.title}
					</a>
				);
			})}
		</div>
	</div>
</div>

<script>
	const island = document.getElementById("dynamic-island");
	const islandTools = document.getElementById("dynamic-island-tools");
	const mobileIsland = document.querySelector(".mobile-island");
	const mobileToggle = document.getElementById("mobile-island-toggle");
	const mobileMenu = document.getElementById("mobile-island-menu");
	const mobileThemeBtn = document.getElementById("mobile-theme-toggle");
	const mobileScrollBtn = document.getElementById("mobile-scroll-top");
	const mobileLabel = document.getElementById("mobile-island-label");
	const threshold = 180;
	const islandHiddenTransform = "translateX(0) scaleY(0.86) translateY(-28px)";
	const toolsHiddenTransform = "translateX(-50%) scaleY(0.86) translateY(-28px)";
	let ticking = false;
	let isVisible = false;
	let toolsVisible = false;

	if (island && islandTools) {
		const getToolsGap = () => 10;
		const getIslandShift = () => {
			const toolsWidth = islandTools.offsetWidth;
			return (toolsWidth + getToolsGap()) / 2;
		};
		const getToolsShift = () => {
			const islandWidth = island.offsetWidth;
			return (islandWidth + getToolsGap()) / 2;
		};
		const getIslandShownTransform = () => `translateX(-${getIslandShift()}px) scaleY(1) translateY(0)`;
		const getToolsShownTransform = () => `translateX(calc(-50% + ${getToolsShift()}px)) scaleY(1) translateY(0)`;

		const setIslandVisible = (visible: boolean) => {
			if (visible) {
				island.classList.remove("opacity-0", "pointer-events-none");
				island.classList.add("opacity-100", "pointer-events-auto");
				island.style.transform = getIslandShownTransform();
				return;
			}

			island.classList.add("opacity-0", "pointer-events-none");
			island.classList.remove("opacity-100", "pointer-events-auto");
			island.style.transform = islandHiddenTransform;
		};

		const setToolsVisible = (visible: boolean) => {
			toolsVisible = visible;
			if (visible) {
				islandTools.classList.remove("opacity-0", "pointer-events-none");
				islandTools.classList.add("opacity-100", "pointer-events-auto");
				islandTools.style.transform = toolsHiddenTransform;
				requestAnimationFrame(() => {
					islandTools.style.transform = getToolsShownTransform();
				});
				return;
			}
			islandTools.classList.add("opacity-0", "pointer-events-none");
			islandTools.classList.remove("opacity-100", "pointer-events-auto");
			islandTools.style.transform = toolsHiddenTransform;
		};

		const handleScroll = () => {
			const isMobile = window.innerWidth <= 640;
			const shouldShow = !isMobile && window.scrollY > threshold;
			if (shouldShow === isVisible) return;
			isVisible = shouldShow;
			if (shouldShow) {
				setIslandVisible(true);
				setToolsVisible(true);
				return;
			}
			setIslandVisible(false);
			setToolsVisible(false);
		};

		const updateTransforms = () => {
			if (isVisible) island.style.transform = getIslandShownTransform();
			if (toolsVisible) islandTools.style.transform = getToolsShownTransform();
		};

		function onScrollOrResize() {
			if (!ticking) {
				window.requestAnimationFrame(() => {
					handleScroll();
					updateTransforms();
					ticking = false;
				});
				ticking = true;
			}
		}

		window.addEventListener("scroll", onScrollOrResize, { passive: true });
		window.addEventListener("resize", onScrollOrResize, { passive: true });
		handleScroll();

		document.getElementById("island-scroll-top")?.addEventListener("click", () => {
			window.scrollTo({ top: 0, behavior: "smooth" });
		});

		document.getElementById("island-theme-toggle")?.addEventListener("click", () => {
			const isDark =
				document.documentElement.classList.contains("dark") ||
				document.documentElement.getAttribute("data-theme") === "dark";
			document.dispatchEvent(
				new CustomEvent("theme-change", {
					detail: { theme: isDark ? "light" : "dark" },
				}),
			);
		});
	}

	if (mobileToggle && mobileMenu && mobileIsland && mobileLabel) {
		let menuOpen = false;
		let menuCloseTimer: number | undefined;

		const closeMenu = () => {
			if (!menuOpen) return;
			menuOpen = false;
			mobileMenu.setAttribute("aria-hidden", "true");
			mobileMenu.classList.remove("is-open");
			mobileToggle.classList.remove("is-open");
			mobileToggle.setAttribute("aria-expanded", "false");
			window.clearTimeout(menuCloseTimer);
			menuCloseTimer = window.setTimeout(() => {
				mobileMenu.hidden = true;
				mobileMenu.classList.remove("is-closing");
			}, 180);
		};

		const openMenu = () => {
			if (menuOpen) return;
			menuOpen = true;
			window.clearTimeout(menuCloseTimer);
			mobileMenu.hidden = false;
			mobileMenu.setAttribute("aria-hidden", "false");
			mobileMenu.classList.add("is-open");
			mobileToggle.classList.add("is-open");
			requestAnimationFrame(() => {
				mobileMenu.classList.remove("is-closing");
			});
			mobileToggle.setAttribute("aria-expanded", "true");
		};

		mobileToggle.addEventListener("click", () => {
			if (menuOpen) {
				mobileMenu.classList.add("is-closing");
				closeMenu();
				return;
			}
			openMenu();
		});

		mobileMenu.addEventListener("click", (event) => {
			const target = event.target;
			if (target instanceof HTMLAnchorElement) {
				mobileLabel.textContent = target.textContent ?? mobileLabel.textContent ?? "";
				closeMenu();
			}
		});

		mobileThemeBtn?.addEventListener("click", () => {
			const isDark =
				document.documentElement.classList.contains("dark") ||
				document.documentElement.getAttribute("data-theme") === "dark";
			document.dispatchEvent(
				new CustomEvent("theme-change", {
					detail: { theme: isDark ? "light" : "dark" },
				}),
			);
			closeMenu();
		});

		mobileScrollBtn?.addEventListener("click", () => {
			window.scrollTo({ top: 0, behavior: "smooth" });
			closeMenu();
		});

	}
</script>

<style>
	.cubic-bezier-apple {
		transition-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	#dynamic-island,
	#dynamic-island-tools {
		backface-visibility: hidden;
		box-shadow:
			0 12px 40px -10px rgba(0, 0, 0, 0.2),
			inset 0 1px 1px 0 rgba(255, 255, 255, 0.3);
	}

	:global(.dark) #dynamic-island,
	:global(.dark) #dynamic-island-tools {
		box-shadow:
			0 25px 60px -12px rgba(0, 0, 0, 0.5),
			inset 0 1px 0.5px 0 rgba(255, 255, 255, 0.1);
	}

	.mobile-island-trigger {
		display: inline-flex;
		flex: 0 0 auto;
		min-width: 0;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		height: 2.65rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.2);
		background: rgba(255, 255, 255, 0.3);
		padding: 0.72rem 0.92rem;
		font-size: 0.92rem;
		font-weight: 600;
		color: hsl(var(--theme-text));
		text-align: center;
		backdrop-filter: blur(24px);
		box-shadow:
			0 12px 44px -10px rgba(0, 0, 0, 0.15),
			inset 0 1px 1px 0 rgba(255, 255, 255, 0.3);
	}

	:global(.dark) .mobile-island-trigger {
		border-color: rgba(255, 255, 255, 0.05);
		background: rgba(0, 0, 0, 0.35);
		box-shadow:
			0 20px 80px rgba(0, 0, 0, 0.5),
			inset 0 1px 0.5px 0 rgba(255, 255, 255, 0.1);
	}

	.mobile-island-chevron {
		transition: transform 260ms cubic-bezier(0.16, 1, 0.3, 1);
	}

	.mobile-island-trigger.is-open .mobile-island-chevron {
		transform: rotate(180deg);
	}

	.mobile-island-actions {
		display: inline-flex;
		flex: 0 0 auto;
		align-items: center;
		gap: 0.3rem;
		height: 2.65rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.2);
		background: rgba(255, 255, 255, 0.3);
		padding: 0.18rem;
		backdrop-filter: blur(24px);
		box-shadow:
			0 12px 44px -10px rgba(0, 0, 0, 0.15),
			inset 0 1px 1px 0 rgba(255, 255, 255, 0.3);
	}

	:global(.dark) .mobile-island-actions {
		border-color: rgba(255, 255, 255, 0.05);
		background: rgba(0, 0, 0, 0.35);
		box-shadow:
			0 20px 80px rgba(0, 0, 0, 0.5),
			inset 0 1px 0.5px 0 rgba(255, 255, 255, 0.1);
	}

	.mobile-island-action {
		display: inline-flex;
		height: 2.1rem;
		width: 2.1rem;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		transition: background-color 180ms ease, color 180ms ease;
	}

	.mobile-island-action:hover {
		background: hsl(var(--theme-text) / 0.06);
	}

	.mobile-island-menu {
		position: absolute;
		left: 0;
		right: 0;
		top: calc(100% + 0.5rem);
		display: grid;
		gap: 0.35rem;
		border-radius: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.2);
		background: rgba(255, 255, 255, 0.3);
		padding: 0.4rem;
		backdrop-filter: blur(24px);
		box-shadow:
			0 12px 44px -10px rgba(0, 0, 0, 0.15),
			inset 0 1px 1px 0 rgba(255, 255, 255, 0.3);
		opacity: 0;
		transform: translateY(-0.35rem) scale(0.98);
		transform-origin: top center;
		visibility: hidden;
		transition:
			opacity 220ms ease,
			transform 260ms cubic-bezier(0.16, 1, 0.3, 1),
			visibility 0s linear 260ms;
		will-change: transform, opacity;
	}

	.mobile-island-menu.is-open {
		opacity: 1;
		transform: translateY(0) scale(1);
		visibility: visible;
		transition:
			opacity 220ms ease,
			transform 260ms cubic-bezier(0.16, 1, 0.3, 1),
			visibility 0s;
	}

	.mobile-island-menu.is-closing {
		opacity: 0;
		transform: translateY(-0.35rem) scale(0.985);
		visibility: visible;
	}

	:global(.dark) .mobile-island-menu {
		border-color: rgba(255, 255, 255, 0.05);
		background: rgba(0, 0, 0, 0.35);
		box-shadow:
			0 20px 80px rgba(0, 0, 0, 0.5),
			inset 0 1px 0.5px 0 rgba(255, 255, 255, 0.1);
	}

	.mobile-island-link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		border-radius: 0.8rem;
		padding: 0.75rem 0.9rem;
		font-size: 0.85rem;
		font-weight: 600;
		color: hsl(var(--theme-text) / 0.78);
		transition: background-color 180ms ease, color 180ms ease;
	}

	.mobile-island-link.is-active {
		background: hsl(var(--theme-accent) / 0.1);
		color: hsl(var(--theme-accent));
	}

	.mobile-island-link:hover {
		background: hsl(var(--theme-accent) / 0.06);
		color: hsl(var(--theme-text));
	}

	@media (max-width: 640px) {
		#island-wrapper {
			top: 0.75rem;
			left: 0.75rem;
			right: 0.75rem;
			transform: none;
			width: auto;
			max-width: none;
			justify-content: stretch;
		}

		.desktop-island {
			display: none !important;
		}

		.mobile-island {
			position: relative;
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			pointer-events: auto;
			width: fit-content;
			max-width: 100%;
			margin: 0 auto;
			white-space: nowrap;
		}

		.mobile-island-trigger {
			min-width: 0;
		}
	}

	@media (min-width: 641px) {
		.mobile-island {
			display: none !important;
		}
	}

	.active-link {
		text-shadow: 0 0 1px rgba(var(--theme-accent), 0.3);
	}
</style>
