---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

const { pub } = Astro.props;
const {
	author,
	title,
	booktitle,
	time,
	doi,
	paper,
	code,
	huggingface,
	site,
	abstract,
	venueIcon,
	venueColor,
	venueRank,
	venueLogo,
	semanticScholarId,
} = pub;

const slug = title
	.toLowerCase()
	.replace(/\s+/g, "-")
	.replace(/[^a-z0-9\-]/g, "");

const isArxivLink = (url: string) => url.includes("arxiv.org");

type CitationCacheEntry = { value: number | null; expiresAt: number };
type CitationCache = Map<string, CitationCacheEntry>;
type CitationInFlight = Map<string, Promise<number | null>>;

const globalWithCache = globalThis as typeof globalThis & {
	__s2CitationCache?: CitationCache;
	__s2CitationInFlight?: CitationInFlight;
};

const citationCache = (globalWithCache.__s2CitationCache ??= new Map());
const citationInFlight = (globalWithCache.__s2CitationInFlight ??= new Map());

const CITATION_TTL_MS = 12 * 60 * 60 * 1000; // 12h
const NEGATIVE_TTL_MS = 2 * 60 * 1000; // 2min
const MAX_RETRIES = 3;
const REQUEST_TIMEOUT_MS = 8000;

const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));
const getCorpusDigits = (raw?: string) => (raw ? raw.replace(/\D/g, "") : "");

const getRetryDelayMs = (res: Response, attempt: number) => {
	const retryAfter = Number(res.headers.get("retry-after"));
	if (Number.isFinite(retryAfter) && retryAfter > 0) return retryAfter * 1000;
	return 400 * 2 ** attempt + Math.floor(Math.random() * 200);
};

const requestCitation = async (
	paperId: string,
	headers: Record<string, string>,
): Promise<number | null> => {
	for (let attempt = 0; attempt <= MAX_RETRIES; attempt++) {
		const controller = new AbortController();
		const timer = setTimeout(() => controller.abort(), REQUEST_TIMEOUT_MS);

		try {
			const res = await fetch(
				`https://api.semanticscholar.org/graph/v1/paper/${encodeURIComponent(paperId)}?fields=citationCount`,
				{ headers, signal: controller.signal },
			);
			clearTimeout(timer);

			if (res.ok) {
				const data = await res.json();
				return typeof data?.citationCount === "number" ? data.citationCount : null;
			}

			if ((res.status === 429 || res.status >= 500) && attempt < MAX_RETRIES) {
				await sleep(getRetryDelayMs(res, attempt));
				continue;
			}

			return null;
		} catch {
			clearTimeout(timer);
			if (attempt < MAX_RETRIES) {
				await sleep(400 * 2 ** attempt + Math.floor(Math.random() * 200));
				continue;
			}
			return null;
		}
	}
	return null;
};

const getCitationCount = async (rawId?: string): Promise<number | null> => {
	const digits = getCorpusDigits(rawId);
	if (!digits) return null;

	const now = Date.now();
	const cached = citationCache.get(digits);
	if (cached && cached.expiresAt > now) return cached.value;

	const inFlight = citationInFlight.get(digits);
	if (inFlight) return inFlight;

	const paperId = `CorpusId:${digits}`;
	const apiKey = import.meta.env.S2_API_KEY; // server-only
	const headers: Record<string, string> = apiKey ? { "x-api-key": apiKey } : {};

	const task = (async () => {
		const value = await requestCitation(paperId, headers);
		citationCache.set(digits, {
			value,
			expiresAt: Date.now() + (value === null ? NEGATIVE_TTL_MS : CITATION_TTL_MS),
		});
		return value;
	})().finally(() => {
		citationInFlight.delete(digits);
	});

	citationInFlight.set(digits, task);
	return task;
};

const citationCount = await getCitationCount(semanticScholarId);
---

<article
	class="pub-article group relative w-full overflow-hidden rounded-xl border border-zinc-200/60 bg-white/80 p-4 backdrop-blur transition duration-200 hover:-translate-y-[1px] hover:border-accent/50 hover:bg-white/90 supports-[backdrop-filter]:bg-white/70 dark:border-zinc-700/60 dark:bg-zinc-900/80 dark:hover:border-accent/60 dark:hover:bg-zinc-900/90"
>
	<div class="grid grid-cols-1 gap-4 lg:flex lg:items-start lg:gap-6">
		<div class="min-w-0 lg:flex-1">
			<h3 class="text-lg font-semibold leading-snug tracking-tight">
				<span class="text-accent">
					{title}
				</span>
			</h3>
			<p class="mt-1 text-gray-700 dark:text-gray-300">
				{
					author.map((name: string, index: number) => (
						<span style={{ fontWeight: name === "Xu Pan" ? "700" : "normal" }}>
							{name}{index < author.length - 1 && ","}
						</span>
					))
				}
			</p>
			<div class="mt-2 flex flex-wrap gap-2">
				<span
					class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700 dark:bg-zinc-800 dark:text-gray-300"
				>
					{
						venueLogo ? (
							<Image
								src={venueLogo}
								alt="Venue logo"
								width={14}
								height={14}
								densities={[1, 2]}
								loading="lazy"
								class="mr-1 inline-block h-[14px] w-[14px] object-contain align-[-0.2em]"
							/>
						) : (
							venueIcon && (
								<Icon
									name={venueIcon}
									width="14"
									height="14"
									class="mr-1 inline-block align-[-0.2em]"
									style={`color: ${venueColor}`}
									aria-hidden="true"
								/>
							)
						)
					}
					{booktitle}
				</span>

				{
					venueRank && (
						<span class="rounded-full bg-accent/10 px-2 py-0.5 text-sm font-medium text-accent dark:bg-accent/15">
							{venueRank}
						</span>
					)
				}

				{
					semanticScholarId && (
						<span
							class="semantic-citation inline-flex items-center rounded-full bg-orange-100 px-2 py-0.5 text-sm font-medium text-orange-700 dark:bg-orange-900/30 dark:text-orange-300"
							title="Semantic Scholar citation count"
						>
							<Icon
								name="simple-icons:semanticscholar"
								class="mr-1 inline-block"
								width="14"
								height="14"
								aria-hidden="true"
							/>
							Citations&nbsp;<span class="citation-count">{citationCount ?? "--"}</span>
						</span>
					)
				}

				{
					time && (
						<span class="rounded-full bg-gray-100 px-2 py-0.5 font-mono text-sm font-medium tabular-nums text-gray-700 dark:bg-zinc-800 dark:text-gray-300">
							{time}
						</span>
					)
				}
			</div>
			<div class="mt-3 flex flex-wrap gap-2" aria-label="Publication actions">
				{
					abstract && (
						<button
							type="button"
							class="abstract-btn cactus-link ui-press inline-flex cursor-pointer items-center rounded border border-zinc-300 px-2.5 py-1 text-xs font-medium text-gray-700 hover:bg-accent/10 dark:border-zinc-700 dark:text-gray-300"
							data-abstract-id={`abstract-${slug}`}
							aria-expanded="false"
						>
							ABSTRACT
							<Icon
								name="lucide:chevron-down"
								class="func-icon chev ml-2 h-3 w-3 transform transition-transform duration-200"
								aria-hidden="true"
							/>
						</button>
					)
				}
				{
					code && (
						<a
							class="cactus-link inline-flex items-center rounded border border-zinc-300 px-2.5 py-1 text-xs font-medium text-gray-700 transition hover:bg-accent/10 dark:border-zinc-700 dark:text-gray-300"
							href={code}
							target="_blank"
							rel="noopener"
						>
							CODE
						</a>
					)
				}
				{
					huggingface && (
						<a
							class="cactus-link inline-flex items-center rounded border border-zinc-300 px-2.5 py-1 text-xs font-medium text-gray-700 transition hover:bg-accent/10 dark:border-zinc-700 dark:text-gray-300"
							href={huggingface}
							target="_blank"
							rel="noopener"
						>
							HF
						</a>
					)
				}
				{
					site && (
						<a
							class="cactus-link inline-flex items-center rounded border border-zinc-300 px-2.5 py-1 text-xs font-medium text-gray-700 transition hover:bg-accent/10 dark:border-zinc-700 dark:text-gray-300"
							href={site}
							target="_blank"
							rel="noopener"
						>
							SITE
						</a>
					)
				}
				{
					doi && (
						<a
							class="cactus-link inline-flex items-center rounded border border-zinc-300 px-2.5 py-1 text-xs font-medium text-gray-700 transition hover:bg-accent/10 dark:border-zinc-700 dark:text-gray-300"
							href={doi}
							target="_blank"
							rel="noopener"
						>
							DOI
						</a>
					)
				}
				{
					paper && (
						<a
							class="cactus-link inline-flex items-center rounded border border-zinc-300 px-2.5 py-1 text-xs font-medium text-gray-700 transition hover:bg-accent/10 dark:border-zinc-700 dark:text-gray-300"
							href={paper}
							target="_blank"
							rel="noopener"
						>
							{isArxivLink(paper) ? (
								<>
									<Icon
										name="simple-icons:arxiv"
										width="14"
										height="14"
										class="mr-1 inline-block"
										style="color: #B31B1B"
										aria-hidden="true"
									/>
									ARXIV
								</>
							) : (
								"PAPER"
							)}
						</a>
					)
				}
			</div>
		</div>

		
	</div>

	{
		abstract && (
			<div
				class="abstract-collapse mt-3 w-full overflow-hidden text-gray-700 transition-[max-height,opacity] duration-300 ease-in-out dark:text-gray-300"
				id={`abstract-content-${slug}`}
				style="max-height: 0; opacity: 0;"
				data-collapsed="true"
			>
				{abstract}
			</div>
		)
	}
</article>
