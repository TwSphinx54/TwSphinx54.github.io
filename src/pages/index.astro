---
import SocialList from "@/components/SocialList.astro";
import PageLayout from "@/layouts/Base.astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import { getEntry } from "astro:content";
import PublicationItem from "@/components/PublicationItem.astro";
import figureImage from "../assets/figure.jpg";

// =========================
// EDITABLE CONTENT (edit here)
// =========================

type PublicationEditable = {
	author: string[];
	title: string;
	booktitle: string;
	time?: string;
	doi?: string;
	paper?: string;
	code?: string;
	huggingface?: string;
	site?: string;
	venueIcon?: string;
	venueColor?: string;
	venueRank?: string;
	venueLogo?: string;
	abstract?: string;
	selected?: boolean;
	openAlexId?: string;
};

type PublicationResolved = PublicationEditable & {
    venueLogo: any | null;
};

type NewsItem = {
	date: string;
	html?: string;
	text?: string;
	href?: string;
	label?: string;
};

type ProjectEditable = {
	name: string;
	description: string;
	tags?: string[];
	time?: string;
	repo?: string;
	site?: string;
	paper?: string;
	orgLogos?: string[];
};

type AckPerson = { name: string; href: string };
type Acknowledgements = {
	title: string;
	introLines?: string[];
	mentors?: AckPerson[];
	peersIntro?: string;
	peers?: AckPerson[];
	outro?: string;
};

type AcademicService = {
	role: string;
	venue: string;
	venueLink?: string;
	year: string;
};

type HonorItem = {
	title: string;
	issuer: string;
	date: string;
};

type RichHtmlToken =
	| { type: "html"; value: string }
	| {
			type: "logo";
			key: string;
			alt: string;
			height: number;
	  };

// =========================
// Content loading (YAML-driven data)
// =========================

// Load editable content from YAML (src/content/home/index.yaml)
const homeEntry = await getEntry("home", "index");
if (!homeEntry) throw new Error("Missing content entry: src/content/home/index.yaml");

const publicationsEditable = homeEntry.data.publicationsEditable as PublicationEditable[];
const newsItems = homeEntry.data.newsItems as NewsItem[];
const projectsEditable = homeEntry.data.projectsEditable as ProjectEditable[];
const experienceMeta = (homeEntry.data.experienceMeta ?? {}) as Record<
	string,
	{ name: string; link: string }
>;
const homeIntroHtml = (homeEntry.data.homeIntroHtml ?? "") as string;
const acknowledgements = (homeEntry.data.acknowledgements ?? null) as Acknowledgements | null;
const personalPhilosophyHtml = (homeEntry.data.personalPhilosophyHtml ?? "") as string;
const academicServices = (homeEntry.data.academicServices ?? []) as AcademicService[];
const honors = (homeEntry.data.honors ?? []) as HonorItem[];

// =========================
// Helpers (pure utilities)
// =========================

function escapeHtml(s: string) {
	return s
		.replaceAll("&", "&amp;")
		.replaceAll("<", "&lt;")
		.replaceAll(">", "&gt;")
		.replaceAll('"', "&quot;")
		.replaceAll("'", "&#039;");
}

function repoLabel(url: string): string {
	try {
		const u = new URL(url);
		const host = u.hostname.toLowerCase();
		if (host === "github.com" || host.endsWith(".github.com")) {
			return u.pathname.replace(/^\/+|\/+$/g, "");
		}
		return url;
	} catch {
		return url;
	}
}

// =========================
// Asset resolution (images/logos)
// =========================

const assetImages = import.meta.glob("../assets/**/*.{png,jpg,jpeg,svg,gif,webp}", {
	eager: true,
	import: "default",
});

function normalizeAssetKey(p: string): string {
	const s = p.trim();
	if (s.startsWith("../assets/")) return s;
	if (s.startsWith("/src/assets/")) return ".." + s.replace("/src", "");
	if (s.startsWith("/assets/")) return "../assets" + s.replace("/assets", "");
	return `../assets/${s}`;
}

function resolveAsset(p?: string): any | null {
	if (!p) return null;
	const key = normalizeAssetKey(p);
	return (assetImages as any)[key] ?? null;
}

function assetToSrc(a: any): string {
	if (!a) return "";
	return typeof a === "string" ? a : a.src;
}

function logoHeight(value: number): number {
	return value;
}

function logoDimensionsForHeight(asset: any, height: number) {
	if (!asset || typeof asset === "string" || !asset.width || !asset.height) {
		return { width: height, height };
	}
	return {
		width: Math.max(1, Math.round((asset.width * height) / asset.height)),
		height,
	};
}

function tokenizeRichHtml(html: string): RichHtmlToken[] {
	if (!html) return [];
	const tokens: RichHtmlToken[] = [];
	const re = /\{\{logo:([^|}]+)\|([^|}]+)\|([^}]+)\}\}/g;
	let lastIndex = 0;

	for (const match of html.matchAll(re)) {
		const index = match.index ?? 0;
		if (index > lastIndex) {
			tokens.push({ type: "html", value: html.slice(lastIndex, index) });
		}

		tokens.push({
			type: "logo",
			key: match[1].trim(),
			alt: match[2].trim(),
			height: logoHeight(Number(match[3]) || 20),
		});

		lastIndex = index + match[0].length;
	}

	if (lastIndex < html.length) {
		tokens.push({ type: "html", value: html.slice(lastIndex) });
	}

	return tokens;
}

// =========================
// Derived data (publications/projects/experiences/logos)
// =========================

const cactusTech: PublicationResolved[] = publicationsEditable
	.map((pub) => {
		const vlogo = resolveAsset(pub.venueLogo);
		return { ...pub, venueLogo: vlogo };
	})
	.filter((p) => p.selected === true);

const projects = projectsEditable;

// Experiences (auto logos from /assets/exps)
const expImages = import.meta.glob("../assets/exps/*.{png,jpg,jpeg,svg,webp}", {
	eager: true,
	import: "default",
});

function expNumericOrder(file: string): number | null {
	const m = file.match(/^exp(\d+)\./i);
	return m ? Number(m[1]) : null;
}

function fileStem(file: string): string {
	return file.replace(/\.[^.]+$/, "");
}

function getExperienceMeta(file: string): { name: string; link: string } {
	const stem = fileStem(file);
	return (
		experienceMeta[file] ||
		experienceMeta[stem] ||
		experienceMeta[file.toLowerCase()] ||
		experienceMeta[stem.toLowerCase()] || { name: stem, link: "#" }
	);
}

const experiences = Object.entries(expImages)
	.map(([path, mod]: [string, any]) => {
		const file = path.split("/").pop() || "";
		const meta = getExperienceMeta(file);
		const altTitleName = meta.name.replace(/\s*\n\s*/g, " ");
		const tooltipHtml = escapeHtml(meta.name).replaceAll("\n", "<br/>");
		return { file, image: mod as any, name: meta.name, altTitleName, tooltipHtml, link: meta.link };
	})
	.sort((a, b) => {
		const an = expNumericOrder(a.file);
		const bn = expNumericOrder(b.file);
		if (an != null && bn != null) return bn - an;
		if (an != null) return -1;
		if (bn != null) return 1;
		return a.file.localeCompare(b.file);
	});

// Logos from /assets/logos
const logoImages = import.meta.glob("../assets/logos/*.{png,svg,jpg,jpeg,webp}", {
	eager: true,
	import: "default",
});

const LOGO_ALIASES: Record<string, string[]> = {
	whu: ["whu", "wuhan"],
};

function findLogoAny(keys: string | string[]) {
	const ks = Array.isArray(keys) ? keys : [keys];
	for (const sub of ks) {
		for (const path of Object.keys(logoImages)) {
			if (path.toLowerCase().includes(sub.toLowerCase())) {
				const mod: any = (logoImages as any)[path];
				return mod || null;
			}
		}
	}
	return null;
}

const projectLogoKeys = new Set<string>(projectsEditable.flatMap((p) => p.orgLogos ?? []));

const projectLogoByKey: Record<string, any | null> = Object.fromEntries(
	[...projectLogoKeys].map((k) => [k, findLogoAny(LOGO_ALIASES[k] ?? k)]),
);

const homeIntroLeadMatch = homeIntroHtml.match(/^\s*<p>([\s\S]*?)<\/p>\s*/);
const homeIntroLeadHtml = homeIntroLeadMatch ? `<p>${homeIntroLeadMatch[1].trim()}</p>` : "";
const homeIntroBodyHtml = homeIntroLeadMatch ? homeIntroHtml.slice(homeIntroLeadMatch[0].length) : homeIntroHtml;
const homeIntroTokens = tokenizeRichHtml(homeIntroBodyHtml);
const personalPhilosophyTokens = tokenizeRichHtml(personalPhilosophyHtml);
const HONORS_PREVIEW_COUNT = 5;
const honorsPreview = honors.slice(0, HONORS_PREVIEW_COUNT);
const honorsRest = honors.slice(HONORS_PREVIEW_COUNT);

const NEWS_PREVIEW_COUNT = 5;
const newsPreview = newsItems.slice(0, NEWS_PREVIEW_COUNT);
const newsRest = newsItems.slice(NEWS_PREVIEW_COUNT);
---

<PageLayout meta={{ title: "Home" }}>
	<section class="rounded-2xl pb-6 pr-6">
		<h1 class="title mb-6">Hello World!</h1>
		{homeIntroLeadHtml && (
			<div class="rich-content space-y-3 mb-3">
				<Fragment set:html={homeIntroLeadHtml} />
			</div>
		)}
		<Image
			src={figureImage}
			alt="Xu Pan"
			width={320}
			height={320}
			sizes="(min-width: 640px) 320px, 320px"
			densities={[1, 2]}
			loading="eager"
			fetchpriority="high"
			class="mb-3 float-right ml-3 h-auto w-39 rounded-md shadow-md sm:ml-4 sm:w-52"
		/>
		{homeIntroTokens.length > 0 && (
			<div class="rich-content space-y-3">
				{homeIntroTokens.map((token) => {
					if (token.type === "html") return <Fragment set:html={token.value} />;
					const src = findLogoAny(LOGO_ALIASES[token.key] ?? token.key);
					if (!src) return null;
					const dims = logoDimensionsForHeight(src, token.height);
					return (
						<Image
							src={src}
							alt={token.alt}
							width={dims.width}
							height={dims.height}
							densities={[1, 2]}
							loading="eager"
							class="inline-logo"
						/>
					);
				})}
			</div>
		)}

		<div class="clear-both">
			<SocialList />
		</div>
	</section>

	<section class="mt-8 rounded-2xl pb-6 pr-6" aria-label="News">
		<h2 class="title mb-4 text-xl">News</h2>
		<ul class="space-y-3 pr-2">
			{
				newsPreview.map((item) => (
					<li class="flex gap-3">
						<span class="w-[5.5rem] shrink-0 font-mono font-medium text-gray-600 dark:text-gray-400">
							{item.date}
						</span>

						<div class="min-w-0 text-gray-700 dark:text-gray-300">
							{item.html ? (
								// NOTE: html is rendered as-is; only put trusted content here
								<span set:html={item.html} />
							) : (
								<>
									{item.text && <span set:html={escapeHtml(item.text)} />}
									{item.href && (
										<>
											{" "}
											<a class="cactus-link" href={item.href} target="_blank" rel="noopener">
												{item.label ?? "More"}
											</a>
										</>
									)}
								</>
							)}
						</div>
					</li>
				))
			}
		</ul>

		{newsRest.length > 0 ? (
			<details class="group mt-3">
				<summary class="flex cursor-pointer list-none items-center justify-center px-3 py-2 text-sm font-semibold tracking-wide text-zinc-500 transition hover:text-accent dark:text-zinc-400 dark:hover:text-accent">
					<span>SHOW {newsRest.length} MORE</span>
					<Icon
						name="lucide:chevron-down"
						class="ml-1 h-3.5 w-3.5 transition-transform duration-200 group-open:rotate-180"
						aria-hidden="true"
					/>
				</summary>
				<ul class="mt-3 space-y-3 pr-2">
					{
						newsRest.map((item) => (
							<li class="flex gap-3">
								<span class="w-[5.5rem] shrink-0 font-mono font-medium text-gray-600 dark:text-gray-400">
									{item.date}
								</span>

								<div class="min-w-0 text-gray-700 dark:text-gray-300">
									{item.html ? (
										<span set:html={item.html} />
									) : (
										<>
											{item.text && <span set:html={escapeHtml(item.text)} />}
											{item.href && (
												<>
													{" "}
													<a class="cactus-link" href={item.href} target="_blank" rel="noopener">
														{item.label ?? "More"}
													</a>
												</>
											)}
										</>
									)}
								</div>
							</li>
						))
					}
				</ul>
			</details>
		) : null}
	</section>

	<section class="mt-8 rounded-2xl pb-6 pr-6" aria-label="Experiences">
		<h2 class="title mb-4 text-xl">Experiences</h2>
		<div class="flex flex-wrap items-center gap-2">
			{
				experiences.map((exp) => (
					<a
						href={exp.link}
						target="_blank"
						rel="noopener"
						aria-label={exp.altTitleName}
						class="group relative flex items-center justify-center p-1"
					>
						<Image
							src={exp.image}
							alt={exp.altTitleName}
							title={exp.altTitleName}
							width={256}
							densities={[1, 2]}
							class="h-14 w-auto object-contain transition-transform duration-200 group-hover:scale-105"
							loading="lazy"
						/>
						<span class="pointer-events-none absolute left-1/2 top-full z-10 mt-1.5 -translate-x-1/2 whitespace-nowrap rounded bg-gray-800 px-2 py-0.5 text-center text-[10px] font-medium leading-snug tracking-wide text-white opacity-0 shadow transition-opacity duration-200 group-hover:opacity-100">
							<span set:html={exp.tooltipHtml} />
						</span>
					</a>
				))
			}
		</div>

		{/* Acknowledgements (YAML-driven via acknowledgements) */}
		{
			acknowledgements && (
				<p class="mt-3 text-sm leading-relaxed text-gray-700 dark:text-gray-300">
					<>
						<b>{acknowledgements.title}</b>
						<br />
					</>

					{acknowledgements.introLines?.map((l) => (
						<>
							{l}
							<br />
						</>
					))}

					{acknowledgements.mentors?.map((p, i) => (
						<>
							<a class="cactus-link" href={p.href}>{p.name}</a>{i < (acknowledgements.mentors?.length ?? 0) - 1 ? "," : ","}
							{i === (acknowledgements.mentors?.length ?? 0) - 1 ? <br /> : " "}
						</>
					))}

					{acknowledgements.peersIntro ? (
						<>
							{acknowledgements.peersIntro}
							<br />
						</>
					) : null}

					{acknowledgements.peers?.map((p, i) => (
						<>
							<a class="cactus-link" href={p.href}>{p.name}</a>{i < (acknowledgements.peers?.length ?? 0) - 1 ? "," : ","}
							{i === (acknowledgements.peers?.length ?? 0) - 1 ? <br /> : " "}
						</>
					))}
					{acknowledgements.outro ? <>{acknowledgements.outro}</> : null}
				</p>
			)
		}
	</section>

	<section class="mt-8" aria-label="Publications">
		<div class="mb-4 flex items-center justify-between">
			<h2 class="title text-xl">Selected Publications</h2>
			<a
				href="/publications"
				aria-label="View all publications"
				class="ui-press group flex items-center gap-x-1.5 rounded-full border border-zinc-200/50 bg-white/70 px-4 py-1.5 text-[10px] font-bold tracking-[0.2em] text-zinc-500 shadow-sm backdrop-blur-md hover:border-accent hover:bg-accent hover:text-white dark:border-zinc-700/50 dark:bg-zinc-900/40 dark:text-zinc-400 dark:hover:border-accent dark:hover:bg-accent dark:hover:text-white"
			>
				VIEW ALL
				<Icon
					name="lucide:arrow-right"
					class="func-icon h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-0.5"
					aria-hidden="true"
				/>
			</a>
		</div>
		<div class="-mx-3 sm:-mx-4 md:-mx-6">
			<dl class="space-y-4 px-3 sm:px-4 md:px-6">
				{cactusTech.map((pub) => <PublicationItem pub={pub} />)}
			</dl>
		</div>
	</section>
	<section class="mt-8" aria-label="Projects">
		<h2 class="title mb-4 text-xl">Projects</h2>

		<div class="-mx-3 sm:-mx-4 md:-mx-6">
			<div class="grid grid-cols-1 gap-4 px-3 sm:px-4 md:grid-cols-2 md:px-6">
				{
					projects.map((p) => (
						<article class="group relative w-full overflow-hidden rounded-xl border border-zinc-200/60 bg-white/80 p-4 backdrop-blur transition duration-200 hover:-translate-y-[1px] hover:border-accent/50 hover:bg-white/90 supports-[backdrop-filter]:bg-white/70 dark:border-zinc-700/60 dark:bg-zinc-900/80 dark:hover:border-accent/60 dark:hover:bg-zinc-900/90">
							<div class="min-w-0">
								<div class="flex flex-wrap items-center gap-2">
									<h3 class="text-lg font-semibold leading-snug tracking-tight text-accent">
										{p.name}
									</h3>
									{p.time && (
										<span class="rounded-full bg-gray-100 px-2 py-0.5 font-mono text-sm font-medium tabular-nums text-gray-700 dark:bg-zinc-800 dark:text-gray-300">
											{p.time}
										</span>
									)}
								</div>

								<p class="mt-2 text-gray-700 dark:text-gray-300">{p.description}</p>

								{p.tags && p.tags.length > 0 && (
									<div class="mt-2 flex flex-wrap gap-2">
										{p.tags.map((t) => (
											<span class="rounded-full bg-gray-100 px-2 py-0.5 text-sm font-medium text-gray-700 dark:bg-zinc-800 dark:text-gray-300">
												{t}
											</span>
										))}
									</div>
								)}

								<div
									class="mt-3 flex items-center justify-between gap-3"
									aria-label="Project links"
								>
									<div class="flex min-w-0 flex-wrap gap-2">
										{p.repo && (
											<a
												class="inline-flex items-center gap-1.5 rounded border border-zinc-300 px-2.5 py-1 text-xs font-medium text-gray-700 transition hover:bg-accent/10 dark:border-zinc-700 dark:text-gray-300 dark:hover:bg-accent/15"
												href={p.repo}
												target="_blank"
												rel="noopener"
												aria-label={`GitHub repo: ${repoLabel(p.repo)}`}
											>
												<Icon
													name="simple-icons:github"
													width="14"
													height="14"
													class="inline-block"
													aria-hidden="true"
												/>
												<span class="truncate">{repoLabel(p.repo)}</span>
											</a>
										)}

										{p.site && (
											<a
												class="cactus-link inline-flex items-center rounded border border-zinc-300 px-2.5 py-1 text-xs font-medium text-gray-700 transition hover:bg-accent/10 dark:border-zinc-700 dark:text-gray-300"
												href={p.site}
												target="_blank"
												rel="noopener"
												aria-label={`${p.name} project site`}
											>
												SITE
											</a>
										)}
										{p.paper && (
											<a
												class="cactus-link inline-flex items-center rounded border border-zinc-300 px-2.5 py-1 text-xs font-medium text-gray-700 transition hover:bg-accent/10 dark:border-zinc-700 dark:text-gray-300"
												href={p.paper}
												target="_blank"
												rel="noopener"
												aria-label={`${p.name} paper`}
											>
												PAPER
											</a>
										)}
									</div>

									{p.orgLogos?.length ? (
										<div class="flex shrink-0 items-center">
											{p.orgLogos.map((k) => {
												const src = projectLogoByKey[k];
												return (
													src && (
														<Image
															src={src}
															alt={`${k} logo`}
															width={28}
															densities={[1, 2]}
															loading="lazy"
															class="ml-1 inline h-5 w-auto object-contain opacity-90"
														/>
													)
												);
											})}
										</div>
									) : null}
								</div>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="mt-8 pb-6 pr-6" aria-label="Honors and Awards">
		<h2 class="title mb-4 text-xl">Honors & Awards</h2>

		{
			honors.length > 0 ? (
				<div class="-mr-6 rounded-xl border border-zinc-200/70 bg-white/80 backdrop-blur supports-[backdrop-filter]:bg-white/70 dark:border-zinc-700/70 dark:bg-zinc-900/80">
					<ul class="divide-y divide-zinc-200/70 dark:divide-zinc-700/70">
						{honorsPreview.map((honor) => (
							<li class="flex items-start justify-between gap-3 px-3 py-1.5 pr-6">
								<div class="min-w-0">
									<p class="leading-5 font-medium text-zinc-800 dark:text-zinc-100">
										{honor.title}
									</p>
									<p class="leading-5 text-zinc-500 dark:text-zinc-400">{honor.issuer}</p>
								</div>
								<span class="w-[5.5rem] shrink-0 text-right font-mono font-medium tabular-nums text-gray-600 dark:text-gray-400">
									{honor.date}
								</span>
							</li>
						))}
					</ul>

					{honorsRest.length > 0 ? (
						<details class="group border-t border-zinc-200/70 dark:border-zinc-700/70">
							<summary class="flex cursor-pointer list-none items-center justify-center px-3 py-2 text-sm font-semibold tracking-wide text-zinc-500 transition hover:text-accent dark:text-zinc-400 dark:hover:text-accent">
								<span>SHOW {honorsRest.length} MORE</span>
								<Icon
									name="lucide:chevron-down"
									class="ml-1 h-3.5 w-3.5 transition-transform duration-200 group-open:rotate-180"
									aria-hidden="true"
								/>
							</summary>
							<ul class="divide-y divide-zinc-200/70 dark:divide-zinc-700/70">
								{honorsRest.map((honor) => (
									<li class="flex items-start justify-between gap-3 px-3 py-1.5 pr-6">
										<div class="min-w-0">
											<p class="leading-5 font-medium text-zinc-800 dark:text-zinc-100">
												{honor.title}
											</p>
											<p class="leading-5 text-zinc-500 dark:text-zinc-400">{honor.issuer}</p>
										</div>
										<span class="w-[5.5rem] shrink-0 text-right font-mono font-medium tabular-nums text-gray-600 dark:text-gray-400">
											{honor.date}
										</span>
									</li>
								))}
							</ul>
						</details>
					) : null}
				</div>
			) : null
		}
	</section>

	<section class="mt-8 rounded-2xl pb-6 pr-6" aria-label="Academic Service">
		<h2 class="title mb-4 text-xl">Academic Service</h2>

		{
			academicServices.length > 0 ? (
				<div class="overflow-x-auto">
					<table class="w-full text-gray-700 dark:text-gray-300">
						<tbody>
							{academicServices.map((service) => (
								<tr class="align-middle">
									<td class="w-6 py-1 pr-2 align-middle">
										<span class="inline-block h-2 w-1 translate-y-[-1.5px] rounded-full bg-accent align-middle" />
									</td>
									<td class="py-1 pr-2 align-middle font-semibold">{service.role}</td>
									<td class="px-2 py-1 align-middle">
										{service.venueLink ? (
											<a
												class="cactus-link"
												href={service.venueLink}
												target="_blank"
												rel="noopener"
												aria-label={`${service.venue} - ${service.role}`}
											>
												{service.venue}
											</a>
										) : (
											<span>{service.venue}</span>
										)}
									</td>
									<td class="whitespace-nowrap py-1 pl-2 text-right align-middle">
										<span class="inline-flex min-w-[4ch] justify-center rounded-full bg-gray-100 px-2 py-0.5 font-mono text-sm font-medium tabular-nums text-gray-700 dark:bg-zinc-800 dark:text-gray-300">
											{service.year}
										</span>
									</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			) : null
		}
	</section>

	{personalPhilosophyTokens.length > 0 ? (
		<section class="mt-8 rounded-2xl pb-6 pr-6" aria-label="Personal Philosophy">
			<h2 class="title mb-4 text-xl">Personal Philosophy</h2>
			<div class="rich-content">
				{personalPhilosophyTokens.map((token) => {
					if (token.type === "html") return <Fragment set:html={token.value} />;
					const src = findLogoAny(LOGO_ALIASES[token.key] ?? token.key);
					if (!src) return null;
					const dims = logoDimensionsForHeight(src, token.height);
					return (
						<Image
							src={src}
							alt={token.alt}
							width={dims.width}
							height={dims.height}
							densities={[1, 2]}
							loading="eager"
							class="inline-logo"
						/>
					);
				})}
			</div>
		</section>
	) : null}
</PageLayout>
